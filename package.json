{
  "name": "saas-agents-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma SaaS multitenant de agentes con WhatsApp, PWA y arquitectura event-driven",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:migrate": "pnpm --filter @saas-agents/db migrate",
    "db:generate": "pnpm --filter @saas-agents/db generate",
    "db:studio": "pnpm --filter @saas-agents/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@turbo/gen": "^1.11.2",
    "prettier": "^3.1.1",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.14.0",
  "dependencies": {
    "@tanstack/react-query": "^5.17.9",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.0.6",
    "lucide-react": "^0.303.0",
    "next-auth": "^4.24.5",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7"
  }
}
